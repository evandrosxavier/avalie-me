meta {
  name: 6 - Erro Regra Negocio Nota Fora Range
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/api/avaliacao
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "descricao": "Curso muito bom, aprendi bastante coisa nova",
    "nota": 15
  }
}

assert {
  res.status: eq 400
  res.body.type: contains regra-negocio
}
