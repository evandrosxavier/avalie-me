meta {
  name: 4 - Erro Nota Ausente
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/api/avaliacao
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "descricao": "Curso muito bom, aprendi bastante coisa nova"
  }
}

assert {
  res.status: eq 400
  res.body.type: contains validacao-entrada
  res.body.detail: contains nota
}
